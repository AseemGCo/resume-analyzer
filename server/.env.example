# Copy this file to ".env" and fill in your key.
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-...

# Any model slug available on OpenRouter. Default is anthropic/claude-sonnet-4.6.
# Other options: anthropic/claude-opus-4.8 (most capable), anthropic/claude-haiku-4.5 (cheapest).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional — used in OpenRouter request headers for attribution / rankings.
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_TITLE=Resume Analyzer

# Port for the API server.
PORT=3001
