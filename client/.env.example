# Base URL of the backend API.
# Local dev: leave empty — Vite proxies /api to http://localhost:3001.
# Split deploy: set to your server's origin (no trailing slash), e.g.
#   VITE_API_BASE_URL=https://resume-analyzer-server.up.railway.app
# Note: Vite bakes this in at BUILD time, so you must redeploy after changing it.
VITE_API_BASE_URL=
